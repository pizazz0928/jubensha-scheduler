# 本地演示模式
AUTH_MODE=demo
LOCAL_STORE_PATH=data/scheduler-state.json

# 腾讯云正式运行，推荐使用门店账号密码登录
# AUTH_MODE=password
# REQUIRE_MYSQL=true
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
# SESSION_SECRET=
# APP_USERS_JSON=[{"username":"admin","passwordHash":"scrypt$16384$8$1$替换为随机盐$替换为密码哈希","displayName":"店长","role":"admin"}]

# 可选的 CloudBase 登录模式
# AUTH_MODE=cloudbase
# 使用英文逗号分隔多个 CloudBase 用户 UID
# CLOUDBASE_ADMIN_UIDS=
# CLOUDBASE_MANAGER_UIDS=
# CLOUDBASE_FRONTDESK_UIDS=

# DM 账号 UID 与 DM 编号的 JSON 映射
# CLOUDBASE_DM_UID_MAP={"uid-1":"dm-aheng","uid-2":"dm-nanzhi"}
